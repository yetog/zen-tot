# Zen TOT Production Environment Variables
# Copy to .env.production and fill in your values

# ============ Frontend Variables (VITE_) ============

# Backend API URL (your IONOS backend)
VITE_BACKEND_URL=https://api.your-domain.com

# IONOS Object Storage (for direct browser uploads via pre-signed URLs)
VITE_IONOS_S3_ENDPOINT=https://s3-eu-central-1.ionoscloud.com
VITE_IONOS_S3_BUCKET=zen-tot-uploads

# ElevenLabs Voice Agent ID (get from ElevenLabs dashboard)
VITE_ELEVENLABS_AGENT_ID=your_agent_id

# ============ Backend Variables (not exposed to frontend) ============

# ElevenLabs API Key (server-side only!)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# IONOS AI Model Hub (server-side only!)
IONOS_API_KEY=your_ionos_jwt_token

# IONOS Object Storage credentials (server-side only!)
IONOS_S3_ACCESS_KEY=your_s3_access_key
IONOS_S3_SECRET_KEY=your_s3_secret_key

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@your-postgres-host:5432/zentot

# JWT Secret for authentication
JWT_SECRET=generate-a-secure-random-string-here

# CORS Origins (comma-separated)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ============ Docker Compose Variables ============

POSTGRES_PASSWORD=your_secure_postgres_password
