# Zen TOT Backend Environment Variables

# ElevenLabs Configuration
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# IONOS AI Model Hub
IONOS_API_KEY=your_ionos_api_key_here

# IONOS Object Storage (S3-compatible)
IONOS_S3_ENDPOINT=https://s3-eu-central-1.ionoscloud.com
IONOS_S3_ACCESS_KEY=your_s3_access_key
IONOS_S3_SECRET_KEY=your_s3_secret_key
IONOS_S3_BUCKET=zen-tot-uploads

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/zentot

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-domain.com

# Server Configuration
PORT=8000
DEBUG=true
